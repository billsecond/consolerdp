--- a/src/PlasmaScreencastV1Session.cpp
+++ b/src/PlasmaScreencastV1Session.cpp
@@ -7,6 +7,7 @@
 #include <QGuiApplication>
 #include <QMouseEvent>
 #include <QQueue>
+#include <QScreen>
 #include <QWaylandClientExtensionTemplate>
 #include <qpa/qplatformnativeinterface.h>
 
@@ -234,6 +235,18 @@ void PlasmaScreencastV1Session::sendEvent(const std::shared_ptr<QEvent> &event)
         auto me = std::static_pointer_cast<QMouseEvent>(event);
         auto position = me->position();
         auto logicalPosition = QPointF{(position.x() / size().width()) * logicalSize().width(), (position.y() / size().height()) * logicalSize().height()};
+        // KWin's fake_input handler treats pointer_motion_absolute as
+        // a *global* compositor coordinate. We've computed a local
+        // coordinate inside our virtual output, so add the output's
+        // origin from Qt's screen list before sending.
+        if (auto vm = virtualMonitor()) {
+            for (auto screen : QGuiApplication::screens()) {
+                if (screen->size() == vm->size) {
+                    logicalPosition += screen->geometry().topLeft();
+                    break;
+                }
+            }
+        }
         d->remoteInterface->pointer_motion_absolute(
             wl_fixed_from_double(logicalPosition.x()),
             wl_fixed_from_double(logicalPosition.y()));
