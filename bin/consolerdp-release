#!/bin/sh
# consolerdp-release — PAM close_session hook. Sends RELEASE.
set -eu

SOCK=/run/consolerdp.sock

case "${PAM_TYPE:-}" in
    close_session) ;;
    *) exit 0 ;;
esac

USER="${PAM_USER:-}"
[ -n "$USER" ] || exit 0

talk() {
    if command -v socat >/dev/null 2>&1; then
        printf 'RELEASE user=%s\n' "$USER" \
            | socat -T2 - "UNIX-CONNECT:$SOCK" || true
    elif command -v python3 >/dev/null 2>&1; then
        python3 - "$SOCK" "$USER" <<'PY' || true
import socket, sys
sock_path, user = sys.argv[1], sys.argv[2]
try:
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(2.0)
    s.connect(sock_path)
    s.sendall(f"RELEASE user={user}\n".encode())
    print(s.recv(4096).decode().strip())
except OSError as e:
    print(f"consolerdp socket error: {e}", file=sys.stderr)
PY
    fi
}

talk | logger -t consolerdp-release
exit 0
