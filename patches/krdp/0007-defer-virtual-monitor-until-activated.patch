--- a/src/RdpConnection.h
+++ b/src/RdpConnection.h
@@ -75,6 +75,17 @@
     State state() const;
     Q_SIGNAL void stateChanged(State newState);
 
+    /**
+     * Emitted after FreeRDP has invoked ``peerActivate``, which only
+     * happens once the client has completed the Demand Active /
+     * Confirm Active exchange and ``peer->context->settings`` carries
+     * its final, negotiated values (including DesktopWidth/Height).
+     *
+     * Consumers that want to read fields populated during capability
+     * exchange should prefer this signal over ``stateChanged(Running)``.
+     */
+    Q_SIGNAL void activated();
+
     /**
      * Desktop size requested by the RDP client during the FreeRDP
      * capability exchange (i.e. ``peer->settings->DesktopWidth/Height``).
--- a/src/RdpConnection.cpp
+++ b/src/RdpConnection.cpp
@@ -524,6 +524,11 @@ bool RdpConnection::onCapabilities()
 
 bool RdpConnection::onActivate()
 {
+    // ``peerActivate`` has just fired in the FreeRDP worker thread, so
+    // peer->context->settings is now authoritative for this connection.
+    // Tell anyone listening (notably SessionController, which needs the
+    // real DesktopWidth/Height before it creates the virtual monitor).
+    Q_EMIT activated();
     return true;
 }
 
