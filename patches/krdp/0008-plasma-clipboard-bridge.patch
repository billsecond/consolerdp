--- a/src/PlasmaScreencastV1Session.cpp
+++ b/src/PlasmaScreencastV1Session.cpp
@@ -8,11 +8,15 @@
 
 #include <QGuiApplication>
 #include <QMouseEvent>
+#include <QMimeData>
 #include <QQueue>
 #include <QScreen>
 #include <QWaylandClientExtensionTemplate>
 #include <qpa/qplatformnativeinterface.h>
 
+#include <KSystemClipboard>
+#include <QClipboard>
+
 #include <linux/input-event-codes.h>
 #include <sys/mman.h>
 #include <xkbcommon/xkbcommon.h>
@@ -174,6 +178,32 @@ PlasmaScreencastV1Session::PlasmaScreencastV1Session()
     // protocol description.
     d->remoteInterface->authenticate(QStringLiteral("KRdp"),
                                      QStringLiteral("Remote Desktop Input"));
+
+    // Bridge the Wayland system clipboard to the RDP CLIPRDR channel.
+    // PortalSession does the same; this ensures the --plasma code path
+    // also synchronises copy/paste between the host and mstsc.
+    connect(KSystemClipboard::instance(), &KSystemClipboard::changed, this,
+        [this](QClipboard::Mode mode) {
+            if (mode != QClipboard::Clipboard) {
+                return;
+            }
+
+            auto data = KSystemClipboard::instance()->mimeData(mode);
+            if (!data) {
+                return;
+            }
+
+            // KSystemClipboard retains ownership of what it returns;
+            // KRdp::Clipboard's setServerData takes ownership of what
+            // we hand it, so deep-copy the formats to a fresh object.
+            auto newData = new QMimeData();
+            const auto formats = data->formats();
+            for (const auto &format : formats) {
+                newData->setData(format, data->data(format));
+            }
+
+            Q_EMIT clipboardDataChanged(newData);
+        });
 }
 
 PlasmaScreencastV1Session::~PlasmaScreencastV1Session()
@@ -307,7 +337,16 @@ void PlasmaScreencastV1Session::sendEvent(const std::shared_ptr<QEvent> &event)
 
 void PlasmaScreencastV1Session::setClipboardData(std::unique_ptr<QMimeData> data)
 {
-    Q_UNUSED(data);
+    // Mirror PortalSession::setClipboardData: hand ownership to
+    // KSystemClipboard, or clear the clipboard when the RDP side
+    // has signalled an empty selection.
+    if (data) {
+        KSystemClipboard::instance()->setMimeData(data.release(),
+                                                  QClipboard::Clipboard);
+    } else {
+        KSystemClipboard::instance()->clear(QClipboard::Clipboard);
+    }
 }
 
 void PlasmaScreencastV1Session::onPacketReceived(const PipeWireEncodedStream::Packet &data)
