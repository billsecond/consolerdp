#!/usr/bin/env bash
# consolerdp-configure -- one-shot post-install wizard.
# Usage:
#   sudo consolerdp-configure --user <seat-user> \
#        [--console-tty N] [--greeter-tty M] [--no-firewall]
#
# What it does:
#   1. Writes /etc/consolerdp/consolerdp.conf with the selected user
#      and TTY numbers (leaves the file alone if already configured).
#   2. Adds the user to the `krdp` group so they can read the SAM
#      file (krdp ships with 0640 root:krdp).
#   3. Disables getty@tty<greeter-tty>.service and enables
#      consolerdp-greeter@tty<greeter-tty>.service.
#   4. Opens UFW tcp/3389 if UFW is active.
#   5. Enables consolerdp.service.
#   6. Enables the per-user session-watcher (systemctl --user).
#   7. Runs consolerdp-doctor to verify.
#
# Re-runnable: safe to invoke multiple times.

set -euo pipefail

SEAT_USER=""
CONSOLE_TTY="2"
GREETER_TTY="8"
DO_FIREWALL=1

usage() {
    sed -n '2,19p' "$0"
    exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --user)         SEAT_USER="$2"; shift 2 ;;
        --console-tty)  CONSOLE_TTY="$2"; shift 2 ;;
        --greeter-tty)  GREETER_TTY="$2"; shift 2 ;;
        --no-firewall)  DO_FIREWALL=0; shift ;;
        -h|--help)      usage 0 ;;
        *)              echo "unknown arg: $1" >&2; usage 1 ;;
    esac
done

[[ $EUID -eq 0 ]] || { echo "must run as root" >&2; exit 1; }
[[ -n "$SEAT_USER" ]] || { echo "--user is required" >&2; exit 1; }
id -u "$SEAT_USER" >/dev/null 2>&1 || \
    { echo "user '$SEAT_USER' does not exist" >&2; exit 1; }

step()  { printf '\n\033[1;36m[%s] %s\033[0m\n' "$1" "$2"; }
ok()    { printf '       \033[1;32m✓ %s\033[0m\n' "$1"; }
warn()  { printf '       \033[1;33m! %s\033[0m\n' "$1"; }

# --------------------------------------------------------------------------- #
step "1/6" "Writing /etc/consolerdp/consolerdp.conf"
install -d -m 0755 /etc/consolerdp
if [[ ! -e /etc/consolerdp/consolerdp.conf ]]; then
    # Ship a default if the package didn't drop one (shouldn't happen,
    # but be defensive so --reconfigure works from a clean slate).
    cat > /etc/consolerdp/consolerdp.conf <<EOF
# /etc/consolerdp/consolerdp.conf
# Generated by consolerdp-configure. Edit and restart consolerdp.

[seat]
user = $SEAT_USER
console_tty = $CONSOLE_TTY
greeter_tty = $GREETER_TTY

[rdp]
port = 3389
watch_interval = 0.5

[policy]
single_rdp = true
lock_on_release = true
EOF
else
    sed -i \
        -e "s|^user = .*|user = $SEAT_USER|" \
        -e "s|^console_tty = .*|console_tty = $CONSOLE_TTY|" \
        -e "s|^greeter_tty = .*|greeter_tty = $GREETER_TTY|" \
        /etc/consolerdp/consolerdp.conf
fi
ok "seat=$SEAT_USER console=tty$CONSOLE_TTY greeter=tty$GREETER_TTY"

# --------------------------------------------------------------------------- #
step "2/6" "Adding $SEAT_USER to required groups"
# krdp's sam file is 0640 root:krdp on Kubuntu; user must be in
# krdp group to read it for NLA auth.
if getent group krdp >/dev/null 2>&1; then
    adduser "$SEAT_USER" krdp >/dev/null 2>&1 || true
    ok "added to 'krdp' group"
else
    warn "no 'krdp' group on this system; krdp package may not be installed"
fi

# --------------------------------------------------------------------------- #
step "3/6" "Configuring greeter on tty${GREETER_TTY}"
systemctl disable --now "getty@tty${GREETER_TTY}.service" 2>/dev/null || true
systemctl enable --now "consolerdp-greeter@tty${GREETER_TTY}.service"
ok "consolerdp-greeter@tty${GREETER_TTY}.service enabled"

# --------------------------------------------------------------------------- #
step "4/6" "Firewall (UFW)"
if [[ "$DO_FIREWALL" -eq 1 ]] && command -v ufw >/dev/null; then
    if ufw status 2>/dev/null | grep -qi 'Status: active'; then
        ufw allow 3389/tcp >/dev/null
        ok "ufw: allow 3389/tcp"
    else
        ok "ufw inactive, no rule needed"
    fi
else
    warn "skipped firewall (--no-firewall or ufw absent)"
fi

# --------------------------------------------------------------------------- #
step "5/6" "Enabling consolerdp.service"
systemctl reset-failed consolerdp.service 2>/dev/null || true
rm -f /run/consolerdp.sock 2>/dev/null || true
systemctl enable --now consolerdp.service
ok "consolerdp.service is active"

# --------------------------------------------------------------------------- #
step "6/6" "Enabling per-user session watcher"
# Running `systemctl --user` as root needs to know the uid.
# Use sudo -u to drop into the user's own systemd --user bus.
uid="$(id -u "$SEAT_USER")"
if [[ -S "/run/user/$uid/bus" ]]; then
    sudo -u "$SEAT_USER" \
        XDG_RUNTIME_DIR="/run/user/$uid" \
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
        systemctl --user daemon-reload 2>/dev/null || true
    sudo -u "$SEAT_USER" \
        XDG_RUNTIME_DIR="/run/user/$uid" \
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$uid/bus" \
        systemctl --user enable --now consolerdp-session-watcher.service \
        || warn "could not enable user service (will auto-start on next login)"
    ok "consolerdp-session-watcher.service enabled for $SEAT_USER"
else
    warn "$SEAT_USER has no active user bus; it will auto-start on their next login"
fi

# --------------------------------------------------------------------------- #
echo
echo "================================================================"
echo " ConsoleRDP configured."
echo "================================================================"
echo "  Seat user     : $SEAT_USER"
echo "  Console TTY   : tty${CONSOLE_TTY}"
echo "  Greeter TTY   : tty${GREETER_TTY}"
echo "  RDP listener  : tcp/3389"
echo "  Host IPs      : $(hostname -I 2>/dev/null | tr -s ' ' || echo '?')"
echo
echo "Next: connect from Windows to this host on port 3389 as '$SEAT_USER'."
echo
echo "Troubleshooting:"
echo "  sudo consolerdp-doctor"
echo "  sudo journalctl -u consolerdp.service -f"
echo
if command -v consolerdp-doctor >/dev/null 2>&1; then
    echo "---- consolerdp-doctor ----"
    consolerdp-doctor || true
fi
